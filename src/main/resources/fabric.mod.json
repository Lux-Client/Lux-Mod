{
  "schemaVersion": 1,
  "id": "lux",
  "version": "${version}",
  "name": "Lux Client",
  "description": "A lightweight, vanilla-style client mod for Minecraft",
  "authors": ["Me!"],
  "contact": { "homepage": "https://github.com/Lux-Client/Lux-Mod" },
  "license": "PolyForm-Shield-1.0.0",
  "icon": "assets/lux/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.lux.fabric.LuxModFabricClient"]
  },
  "mixins": ["lux.mixins.json"],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": ">=1.21",
    "java": ">=21",
    "fabric-api": ">=0.100.0"
  },
  "suggests": {
    "sodium": "*",
    "iris": "*"
  }
}
